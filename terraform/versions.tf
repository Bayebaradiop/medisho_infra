terraform {
  required_version = ">= 1.5"

  required_providers {
    azurerm = {
      source  = "hashicorp/azurerm"
      version = "~> 4.0"
    }
  }
}

provider "azurerm" {
  features {}

  # Depuis la v4 du provider, la souscription doit etre explicite.
  subscription_id = var.subscription_id
}
